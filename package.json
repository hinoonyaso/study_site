{
  "name": "physical-ai-study-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "serve:study": "node scripts/serve-static.mjs --host 0.0.0.0 --port 4173 --base /study_site/",
