    "@types/three": "^0.184.0",
    "@uiw/react-codemirror": "^4.23.10",
    "@vitejs/plugin-react": "^5.0.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
